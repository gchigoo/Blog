<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <% if (typeof analyticsEventToken === 'string' && analyticsEventToken) { %>
    <meta name="analytics-event-token" content="<%= analyticsEventToken %>">
    <script src="<%= typeof assetUrl === 'function' ? assetUrl('/js/analytics-context.js') : '/js/analytics-context.js' %>" defer></script>
  <% } %>
  <title><%= typeof seo !== 'undefined' && seo?.title ? seo.title + ' - ' : (typeof title !== 'undefined' ? title + ' - ' : '') %><%= typeof site !== 'undefined' ? site.title : '我的博客' %></title>
  <% if (typeof seo !== 'undefined' && seo) { %>
    <meta name="description" content="<%= seo.description %>">
    <link rel="canonical" href="<%= seo.canonical %>">
    <meta property="og:title" content="<%= seo.title %>">
    <meta property="og:description" content="<%= seo.description %>">
    <meta property="og:type" content="<%= seo.type %>">
    <meta property="og:url" content="<%= seo.canonical %>">
    <% if (seo.noindex) { %><meta name="robots" content="noindex,follow"><% } %>
  <% } %>
  <link rel="alternate" type="application/rss+xml" title="RSS" href="/feed.xml">
  <link rel="stylesheet" href="<%= typeof assetUrl === 'function' ? assetUrl('/vendor/inter.css') : '/vendor/inter.css' %>">
  <link rel="stylesheet" href="<%= typeof assetUrl === 'function' ? assetUrl('/vendor/new.css/new.min.css') : '/vendor/new.css/new.min.css' %>">
  <link rel="stylesheet" href="<%= typeof assetUrl === 'function' ? assetUrl('/css/highlight.css') : '/css/highlight.css' %>">
  <link rel="stylesheet" href="<%= typeof assetUrl === 'function' ? assetUrl('/css/custom.css') : '/css/custom.css' %>">
</head>
<body>
  <header>
    <h1><a href="/" style="text-decoration: none; color: inherit;">我的博客</a></h1>
    <nav>
      <a href="/">首页</a> /
      <a href="/archive">归档</a> /
      <a href="/tags">标签</a> /
      <a href="/search">搜索</a> /
      <a href="/feed.xml">RSS</a> /
      <a href="/about">关于</a>
      <% if (typeof user !== 'undefined' && user) { %>
        / <a href="/admin">管理</a>
      <% } %>
    </nav>
  </header>
  
  <main>
