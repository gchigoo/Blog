<%- include('partials/header', { title: '首页', user }) %>

<h2>最新文章</h2>

<% if (articles.length === 0) { %>
  <p>还没有文章，<% if (typeof user !== 'undefined' && user) { %><a href="/admin/upload">立即发布</a><% } else { %>敬请期待！<% } %></p>
<% } else { %>
  <ul class="article-list">
    <% articles.forEach(article => { %>
      <li>
        <a href="/article/<%= article.slug %>"><%= article.title %></a>
        <span class="article-meta">
          <%= typeof formatDate === 'function' ? formatDate(article.created_at, { year: 'numeric', month: '2-digit', day: '2-digit' }) : article.created_at %>
          <% if (article.tags && article.tags.length > 0) { %>
            · 
            <% article.tags.forEach((tag, index) => { %>
              <a href="/tag/<%= encodeURIComponent(tag) %>" class="tag"><%= tag %></a><% if (index < article.tags.length - 1) { %> <% } %>
            <% }) %>
          <% } %>
        </span>
      </li>
    <% }) %>
  </ul>
  
  <% if (totalPages > 1) { %>
    <nav class="pagination" aria-label="文章分页">
      <% if (page > 1) { %><a href="/?page=<%= page - 1 %>" rel="prev">← 上一页</a><% } %>
      <% const firstPage = Math.max(1, page - 3); const lastPage = Math.min(totalPages, page + 3); %>
      <% for (let number = firstPage; number <= lastPage; number += 1) { %>
        <a href="/?page=<%= number %>" <%= number === page ? 'aria-current=page' : '' %>><%= number %></a>
      <% } %>
      <% if (page < totalPages) { %><a href="/?page=<%= page + 1 %>" rel="next">下一页 →</a><% } %>
    </nav>
  <% } %>
<% } %>

<%- include('partials/footer') %>
