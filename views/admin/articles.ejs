<%- include('../partials/admin-header', { title: '文章列表' }) %>

<h2>文章列表</h2>

<div id="message"></div>

<p>共 <%= articles.length %> 篇文章</p>

<% if (articles.length === 0) { %>
  <p>暂无文章，<a href="/admin/upload">立即上传</a></p>
<% } else { %>
  <table style="width: 100%; border-collapse: collapse;">
    <thead>
      <tr>
        <th style="text-align: left; padding: 0.5em;">标题</th>
        <th style="text-align: left; padding: 0.5em;">标签</th>
        <th style="text-align: left; padding: 0.5em;">状态</th>
        <th style="text-align: left; padding: 0.5em;">发布日期</th>
        <th style="text-align: center; padding: 0.5em;">操作</th>
      </tr>
    </thead>
    <tbody>
      <% articles.forEach(article => { %>
        <tr>
          <td style="padding: 0.5em;">
            <% if (article.status === 'published') { %><a class="article-title" href="/article/<%= article.slug %>" target="_blank" rel="noopener"><%= article.title %></a><% } else { %><span class="article-title"><%= article.title %></span><% } %>
          </td>
          <td style="padding: 0.5em;">
            <% if (article.tags && article.tags.length > 0) { %>
              <% article.tags.forEach(tag => { %>
                <span class="tag"><%= tag %></span>
              <% }) %>
            <% } else { %>
              -
            <% } %>
          </td>
          <td style="padding: 0.5em;"><%= article.status === 'draft' ? '草稿' : '已发布' %></td>
          <td style="padding: 0.5em;">
            <%= typeof formatDate === 'function' ? formatDate(article.created_at, { year: 'numeric', month: '2-digit', day: '2-digit' }) : article.created_at %>
          </td>
          <td style="padding: 0.5em; text-align: center;">
            <a href="/admin/upload?replaceId=<%= article.id %>">替换</a>
            <button type="button" class="delete-article" data-article-id="<%= article.id %>" style="background: #dc3545; color: white;">删除</button>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
<% } %>

<script>
  const messageDiv = document.getElementById('message');

  document.querySelectorAll('.delete-article').forEach(button => {
    button.addEventListener('click', () => {
      const title = button.closest('tr').querySelector('.article-title').textContent;
      deleteArticle(button.dataset.articleId, title);
    });
  });
  
  // 删除文章
  async function deleteArticle(id, title) {
    if (!confirm(`确定要删除文章"${title}"吗？此操作不可恢复！`)) {
      return;
    }
    
    try {
      const response = await fetch(`/api/admin/articles/${id}`, {
        method: 'DELETE'
      });
      
      const data = await response.json();
      
      if (response.ok) {
        showMessage('success', '文章已删除');
        setTimeout(() => {
          window.location.reload();
        }, 1000);
      } else {
        showMessage('error', data.error || '删除失败');
      }
    } catch (error) {
      showMessage('error', '网络错误，请稍后重试');
    }
  }
  
  function showMessage(type, message) {
    const content = document.createElement('div');
    content.classList.add('message', type);
    content.textContent = message;
    messageDiv.replaceChildren(content);
  }
</script>

<%- include('../partials/admin-footer') %>
