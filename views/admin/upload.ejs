<%- include('../partials/admin-header', { title: '上传文章' }) %>

<h2>上传文章</h2>

<div id="message" role="status" aria-live="polite"></div>

<div class="upload-area" id="uploadArea" role="button" tabindex="0" aria-controls="fileInput">
  <p>点击选择文件或拖拽文件到此处</p>
  <p style="font-size: 0.9em; color: #666;">支持 .md 或 .zip 文件（ZIP 包含 Markdown 和图片）</p>
  <input type="file" id="fileInput" accept=".md,.zip" style="display: none;">
</div>

<div id="fileInfo" class="file-info" style="display: none;">
  <h3>文件信息</h3>
  <p><strong>文件名:</strong> <span id="fileName"></span></p>
  <p><strong>文件大小:</strong> <span id="fileSize"></span></p>
  <button id="previewBtn" type="button">预览</button>
  <button id="uploadBtn" type="button">上传</button>
  <button id="cancelBtn" type="button">取消</button>
</div>

<div id="uploadProgress" style="display: none; margin-top: 1em;" role="status">
  <p>处理中... <span class="loading"></span></p>
</div>

<section id="previewPanel" class="upload-preview" aria-labelledby="previewTitle" hidden>
  <h3 id="previewTitle">文章预览</h3>
  <iframe id="previewFrame" title="文章渲染预览" sandbox="allow-same-origin"></iframe>
</section>

<hr style="margin-top: 3em;">

<h3>Markdown 格式说明</h3>
<p>文章必须包含 Front Matter（文件开头的元数据）：</p>
<pre><code>---
title: 文章标题
description: 一句话摘要
tags: [标签1, 标签2]
status: published # 或 draft
date: 2026-01-16
---

文章正文内容...

## 二级标题

段落文本...

![图片说明](./images/pic.jpg)
</code></pre>

<p><strong>图片处理:</strong></p>
<ul>
  <li>上传 .zip 文件时，会自动查找并转换图片为 WebP 格式</li>
  <li>图片会自动压缩以节省带宽</li>
  <li>建议将图片和 Markdown 文件打包成 ZIP 一起上传</li>
</ul>

<script>
  const uploadArea = document.getElementById('uploadArea');
  const fileInput = document.getElementById('fileInput');
  const fileInfo = document.getElementById('fileInfo');
  const fileName = document.getElementById('fileName');
  const fileSize = document.getElementById('fileSize');
  const previewBtn = document.getElementById('previewBtn');
  const uploadBtn = document.getElementById('uploadBtn');
  const cancelBtn = document.getElementById('cancelBtn');
  const uploadProgress = document.getElementById('uploadProgress');
  const messageDiv = document.getElementById('message');
  const previewPanel = document.getElementById('previewPanel');
  const previewFrame = document.getElementById('previewFrame');
  const replaceId = new URLSearchParams(window.location.search).get('replaceId');
  
  let selectedFile = null;
  
  // 点击上传区域
  uploadArea.addEventListener('click', () => {
    fileInput.click();
  });
  uploadArea.addEventListener('keydown', (event) => {
    if (event.key === 'Enter' || event.key === ' ') {
      event.preventDefault();
      fileInput.click();
    }
  });
  
  // 文件选择
  fileInput.addEventListener('change', (e) => {
    handleFile(e.target.files[0]);
  });
  
  // 拖拽上传
  uploadArea.addEventListener('dragover', (e) => {
    e.preventDefault();
    uploadArea.classList.add('dragover');
  });
  
  uploadArea.addEventListener('dragleave', () => {
    uploadArea.classList.remove('dragover');
  });
  
  uploadArea.addEventListener('drop', (e) => {
    e.preventDefault();
    uploadArea.classList.remove('dragover');
    handleFile(e.dataTransfer.files[0]);
  });
  
  // 处理文件
  function handleFile(file) {
    if (!file) return;
    
    const ext = file.name.split('.').pop().toLowerCase();
    if (ext !== 'md' && ext !== 'zip') {
      showMessage('error', '仅支持 .md 或 .zip 文件');
      return;
    }
    
    selectedFile = file;
    fileName.textContent = file.name;
    fileSize.textContent = formatFileSize(file.size);
    fileInfo.style.display = 'block';
    uploadArea.style.display = 'none';
  }
  
  // 取消选择
  cancelBtn.addEventListener('click', () => {
    selectedFile = null;
    fileInput.value = '';
    fileInfo.style.display = 'none';
    uploadArea.style.display = 'block';
    previewPanel.hidden = true;
    previewFrame.removeAttribute('srcdoc');
  });

  async function submitFile(endpoint) {
    const formData = new FormData();
    formData.append('file', selectedFile);
    if (replaceId) formData.append('replaceId', replaceId);
    const response = await fetch(endpoint, { method: 'POST', body: formData });
    const data = await response.json();
    if (!response.ok) throw new Error(data.error || '请求失败');
    return data;
  }

  previewBtn.addEventListener('click', async () => {
    if (!selectedFile) return;
    previewBtn.disabled = true;
    uploadProgress.style.display = 'block';
    try {
      const preview = await submitFile('/api/admin/preview');
      previewFrame.srcdoc = `<!doctype html><meta charset="utf-8"><link rel="stylesheet" href="/vendor/new.css/new.min.css"><link rel="stylesheet" href="/css/custom.css"><main>${preview.html}</main>`;
      previewPanel.hidden = false;
      previewPanel.scrollIntoView({ behavior: 'smooth', block: 'start' });
    } catch (error) {
      showMessage('error', error.message);
    } finally {
      previewBtn.disabled = false;
      uploadProgress.style.display = 'none';
    }
  });
  
  // 上传文件
  uploadBtn.addEventListener('click', async () => {
    if (!selectedFile) return;
    
    uploadBtn.disabled = true;
    cancelBtn.disabled = true;
    uploadProgress.style.display = 'block';
    messageDiv.replaceChildren();
    
    try {
      const data = await submitFile('/api/admin/upload');
      uploadProgress.style.display = 'none';
      showUploadSuccess(data.article);
      selectedFile = null;
      fileInput.value = '';
      fileInfo.style.display = 'none';
      uploadArea.style.display = 'block';
    } catch (error) {
      uploadProgress.style.display = 'none';
      showMessage('error', error.message || '网络错误，请稍后重试');
    } finally {
      uploadBtn.disabled = false;
      cancelBtn.disabled = false;
    }
  });
  
  // 辅助函数
  function formatFileSize(bytes) {
    if (bytes < 1024) return bytes + ' B';
    if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(2) + ' KB';
    return (bytes / (1024 * 1024)).toFixed(2) + ' MB';
  }

  function showUploadSuccess(article) {
    const content = document.createElement('div');
    content.classList.add('message', 'success');
    content.append('文章上传成功！ 标题: ');

    const title = document.createElement('span');
    title.textContent = article.title;
    const action = article.replaced ? '文章替换成功！' : article.status === 'draft' ? '草稿保存成功！' : '文章上传成功！';
    content.firstChild.textContent = `${action} 标题: `;
    content.append(title, ` Slug: ${article.slug} 图片转换: ${article.imagesConverted} 张`);
    if (article.imageWarnings?.length) {
      content.append(`；${article.imageWarnings.length} 张图片转换失败，请检查：${article.imageWarnings.join('、')}`);
      content.classList.remove('success');
      content.classList.add('info');
    }
    messageDiv.replaceChildren(content);
  }
  
  function showMessage(type, message) {
    const content = document.createElement('div');
    content.classList.add('message', type);
    content.textContent = message;
    messageDiv.replaceChildren(content);
  }
</script>

<%- include('../partials/admin-footer') %>
