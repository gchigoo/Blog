{
  "name": "minimalist-blog",
  "version": "1.0.0",
  "description": "极简个人博客系统 - Markdown + new.css",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "test": "node --test test/*.test.js",
    "typecheck": "tsc",
    "lint": "eslint \"server/analytics/**/*.js\" test/analytics-query.test.js test/analytics-browser.test.js",
    "test:view-hashes": "node test/visual/verify-view-hashes.js",
    "test:baseline-manifest": "node test/visual/verify-baseline-manifest.js",
    "test:html-snapshots": "playwright test ejs-html.spec.js",
    "test:visual": "playwright test ejs-visual.spec.js",
    "test:article-audio-browser": "playwright test article-audio-browser.spec.js",
    "test:ejs-upgrade-gate": "npm run test:view-hashes && npm run test:baseline-manifest && npm test && npm run test:html-snapshots && npm run test:visual",
    "visual:evidence": "node test/visual/generate-baseline-evidence.js",
    "init-db": "node server/scripts/init-db.js",
    "query-db": "node scripts/query-db.js",
    "backup-db": "node scripts/backup-db.js",
    "change-password": "node scripts/change-password.js"
  },
  "engines": {
    "node": ">=24 <25"
  },
  "keywords": [
    "blog",
    "markdown",
    "minimalist"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@maxmind/geoip2-node": "^7.1.0",
    "adm-zip": "^0.6.0",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.11.1",
    "bowser": "^2.14.1",
    "cookie-parser": "^1.4.7",
    "ejs": "6.0.1",
    "express": "^5.2.1",
    "google-auth-library": "^10.9.0",
    "gray-matter": "^4.0.3",
    "jsonwebtoken": "^9.0.2",
    "markdown-it": "^14.3.0",
    "markdown-it-anchor": "^9.2.1",
    "multer": "^2.2.0",
    "sharp": "^0.35.3",
    "slugify": "^1.6.9"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.0",
    "@types/node": "24.13.3",
    "eslint": "10.7.0",
    "globals": "17.7.0",
    "nodemon": "^3.1.14",
    "typescript": "5.9.3"
  }
}
