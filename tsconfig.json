{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "skipLibCheck": true
  },
  "include": [
    "server/**/*.js",
    "scripts/**/*.js"
  ],
  "exclude": [
    "node_modules"
  ]
}
